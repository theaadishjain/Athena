# Monorepo root gitignore

# Dependencies
node_modules/
**/venv/
.venv/

# Environment Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Next.js Build
frontend/.next/
frontend/out/

# Databases
backend/studyco.db
*.db
*.sqlite

# Python Cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS Files
.DS_Store
Thumbs.db

# Media/Temporary
test_output.json
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Graphify
graphify/
graphify-out/
.graphify*

# Stray lock files at repo root
package-lock.json
yarn.lock

# Clerk keyless cache
.clerk/

# Temp files
test_doc.txt

# Docker
.docker/
docker-compose.override.yml

# Docker volumes (never commit persistent data)
studyco_mempalace_data/
studyco_sqlite_data/

# Backend runtime artifacts
backend/studyco.db
backend/*.db
backend/__pycache__/
backend/.env
backend/venv/
backend/.venv/

# Frontend runtime artifacts
frontend/.next/
frontend/node_modules/
frontend/.env.local


