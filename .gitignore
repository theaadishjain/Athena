node_modules/
**/venv/
.venv/

# Environment Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Next.js Build
frontend/.next/
frontend/out/

# Databases
backend/studyco.db
*.db
*.sqlite

# Python Cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS Files
.DS_Store
Thumbs.db

# Media/Temporary
test_output.json
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Graphify
graphify/
graphify-out/
.graphify*

